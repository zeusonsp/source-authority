# Source Authority — Landing environment
# Copie este arquivo para apps/landing/.env.local e preencha com valores reais.
# .env.local NUNCA é commitado (ver .gitignore raiz).

# ── Supabase (Project Settings → API) ──────────────────────────────────────
# Mesmo project que apps/web. SUPABASE_URL pode reaproveitar
# NEXT_PUBLIC_SUPABASE_URL — mas explicitar deixa claro que esse env é
# server-only (server action insere via service_role).
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# Novo formato (legacy JWT eyJhbG... está sendo desativado pelo Supabase).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (e-mail — único canal de notificação no Lote B2) ───────────────
# API key criada em https://resend.com/api-keys (formato re_XXXXX)
# Lote B: from = onboarding@resend.dev (sandbox do Resend, sem DNS).
# Lote B3: trocar pra noreply@sourceauthority.com.br após SPF/DKIM no
# Cloudflare.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Lote B2: zeusonsp@gmail.com (limitação Resend free sem domain verification).
# Lote B3: trocar pra nathanturra_r@hotmail.com após verificação de
# sourceauthority.com.br no Resend (SPF/DKIM via Cloudflare).
LEADS_NOTIFICATION_EMAIL=zeusonsp@gmail.com

# ── Upstash Redis (rate limit) ─────────────────────────────────────────────
# Criar database em https://console.upstash.com/redis. URL + token estão
# em "REST API" do dashboard.
# Limite atual: 10 submissions / IP / 10 min (rate-limit.ts).
UPSTASH_REDIS_REST_URL=https://xxxxx-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=Axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
