# Source Authority — Web app environment
# Copie este arquivo para apps/web/.env.local e preencha com valores reais.
# .env.local NUNCA é commitado (ver .gitignore raiz).

# Supabase (Project Settings → API)
# OBRIGATÓRIAS a partir do próximo chunk (integração Supabase).
# Neste chunk inicial, podem ficar vazias — o app boota com defaults.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# Novo formato (legacy JWT eyJhbG... está sendo desativado pelo Supabase).
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App URL — produção: https://app.sourceauthority.com.br
# Dev local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
