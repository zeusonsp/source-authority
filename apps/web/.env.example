# Source Authority — Web app environment
# Copie este arquivo para apps/web/.env.local e preencha com valores reais.
# .env.local NUNCA é commitado (ver .gitignore raiz).

# Supabase (Project Settings → API)
# OBRIGATÓRIAS a partir do próximo chunk (integração Supabase).
# Neste chunk inicial, podem ficar vazias — o app boota com defaults.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# App URL (dev local; em prod será https://app.sourceauthority.com.br)
NEXT_PUBLIC_APP_URL=http://localhost:3000
