# Source Authority — Web app environment
# Copie este arquivo para apps/web/.env.local e preencha com valores reais.
# .env.local NUNCA é commitado (ver .gitignore raiz).

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# Novo formato (legacy JWT eyJhbG... está sendo desativado pelo Supabase).
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App URL — produção: https://app.sourceauthority.com.br
# Dev local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tracker (Cloudflare Worker) — base URL pública. Ver apps/web/src/lib/tracker.ts.
# Fallback é o subdomínio .workers.dev atual; troca quando custom domain bater.
# NEXT_PUBLIC_TRACKER_BASE_URL=https://go.sourceauthority.com.br

# Resend — emails transacionais (alertas + digest). Mesma conta do apps/landing.
# Resend Dashboard → API Keys → "source-authority" (ou crie nova).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret pros endpoints internos /api/internal/alerts/notify e /digest.
# Vem do worker brand-monitor (Bearer header). Gere com `openssl rand -hex 32`.
# MESMO valor precisa estar em workers/brand-monitor (wrangler secret put).
INTERNAL_NOTIFICATIONS_SECRET=change-me-to-64-hex-chars-from-openssl-rand-hex-32

# Stripe (Fase 7 — billing)
# Secret key — sk_test_xxx em dev, sk_live_xxx em prod (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
# Webhook signing secret — whsec_xxx (Dashboard → Developers → Webhooks → seu endpoint → "Signing secret")
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
# Price IDs — um por plano. Criados via scripts/stripe-setup.cjs.
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_GROWTH=price_growth_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_BUSINESS=price_business_placeholder
